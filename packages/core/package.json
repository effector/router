{
  "name": "@effector/router",
  "version": "1.1.1",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "private": false,
  "description": "Flexible type-safe routing for apps",
  "keywords": [
    "effector",
    "router",
    "argon",
    "atomic",
    "effector/router"
  ],
  "contributors": [
    "Sergey Sova <mail@sergeysova.com>",
    "Anton Kosykh",
    "Zero Bias <ribkatt@gmail.com>",
    "movpushmov"
  ],
  "homepage": "https://router.effector.dev/core",
  "license": "MIT",
  "directories": {
    "lib": "lib"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/effector/router.git",
    "directory": "packages/core"
  },
  "scripts": {
    "build": "vite build",
    "test": "vitest run"
  },
  "bugs": {
    "url": "https://github.com/effector/router/issues?q=is%3Aissue%20label%3Ascope%3Acore"
  },
  "peerDependencies": {
    "effector": "catalog:peer",
    "effector-action": ">=1.2.2",
    "patronum": ">=2.2",
    "query-string": "^9.1.1",
    "zod": ">=4"
  },
  "dependencies": {
    "@effector/router-paths": "workspace:^"
  }
}
