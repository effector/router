{
  "name": "@effector/router-solid",
  "version": "0.0.1",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "private": false,
  "description": "SolidJS bindings for effector router",
  "keywords": [
